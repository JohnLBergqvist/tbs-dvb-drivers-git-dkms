Subject: [PATCH] Rename APSK_NL to APSK_N_L

TBS drivers reference modulation enum names with no underscore between
the digits and the L suffix (APSK_8L, APSK_16L, APSK_32L, APSK_64L,
APSK_256L). Mainline Linux uses underscored forms (APSK_8_L, APSK_16_L,
APSK_32_L, APSK_64_L). Out-of-tree builds against mainline fail with:

    error: 'APSK_8L' undeclared (first use in this function);
    did you mean 'APSK_8_L'?

Rename all such references to use the underscored form. Mainline
defines APSK_8_L through APSK_64_L; APSK_128_L / APSK_256_L don't
exist in mainline so they're defined in src/frontend_extra.h alongside
the other DVB-S2X additions.

Affects 2 files: si2183.c (3 sites) and stid135/stid135-fe.c (5 sites).
---
diff --git a/drivers/media/dvb-frontends/si2183.c b/drivers/media/dvb-frontends/si2183.c
index a275fe8..075819f 100644
--- a/drivers/media/dvb-frontends/si2183.c
+++ b/drivers/media/dvb-frontends/si2183.c
@@ -348,16 +348,16 @@ static int si2183_read_status(struct dvb_frontend *fe, enum fe_status *status)
 			c->modulation = APSK_16;
 			break;
 			case 0x17:
-			c->modulation = APSK_8L;
+			c->modulation = APSK_8_L;
 			break;
 			case 0x18:
-			c->modulation = APSK_16L;
+			c->modulation = APSK_16_L;
 			break;
 			case 0x15:
 			c->modulation = APSK_32;
 			break;
 			case 0x19:
-			c->modulation = APSK_32L;
+			c->modulation = APSK_32_L;
 			break;
 			case 0x1a:
 			c->modulation = APSK_32;
diff --git a/drivers/media/dvb-frontends/stid135/stid135-fe.c b/drivers/media/dvb-frontends/stid135/stid135-fe.c
index 161ec94..b42104f 100644
--- a/drivers/media/dvb-frontends/stid135/stid135-fe.c
+++ b/drivers/media/dvb-frontends/stid135/stid135-fe.c
@@ -538,19 +538,19 @@ static int stid135_get_frontend(struct dvb_frontend *fe, struct dtv_frontend_pro
 		p->modulation = APSK_1024;
 		break;
 	case FE_SAT_MOD_8PSK_L:
-		p->modulation = APSK_8L;
+		p->modulation = APSK_8_L;
 		break;
 	case FE_SAT_MOD_16APSK_L:
-		p->modulation = APSK_16L;
+		p->modulation = APSK_16_L;
 		break;
 	case FE_SAT_MOD_32APSK_L:
-		p->modulation = APSK_32L;
+		p->modulation = APSK_32_L;
 		break;
 	case FE_SAT_MOD_64APSK_L:
-		p->modulation = APSK_64L;
+		p->modulation = APSK_64_L;
 		break;
 	case FE_SAT_MOD_256APSK_L:
-		p->modulation = APSK_256L;
+		p->modulation = APSK_256_L;
 		break;
 	case FE_SAT_MOD_QPSK:
 	default:
